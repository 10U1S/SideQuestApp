<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/soft_background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/settings_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:title="Einstellungen"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- SEKTION: QUESTS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUESTS"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:shadowColor="#1565C0"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="10"
                android:layout_marginBottom="15dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/quest_card_bg"
                android:layout_marginBottom="30dp">

                <TextView
                    android:id="@+id/tv_radius_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quest-Radius: 50 km"
                    android:textColor="#0D47A1"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />

                <SeekBar
                    android:id="@+id/seekbar_radius"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="490"
                    android:progress="40"
                    android:progressTint="#2196F3"
                    android:thumbTint="#0D47A1" />
            </LinearLayout>

            <!-- SEKTION: DATEN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENTWICKLEROPTIONEN"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:shadowColor="#1565C0"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="10"
                android:layout_marginBottom="15dp" />

            <Button
                android:id="@+id/btn_import_csv"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Eigene CSV importieren"
                android:background="@drawable/aero_button"
                android:backgroundTint="@null"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="15dp" />

            <Button
                android:id="@+id/btn_upload_to_firebase"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Alle CSV zu Firebase hochladen"
                android:background="@drawable/aero_button"
                android:backgroundTint="@null"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="15dp" />

            <Button
                android:id="@+id/btn_delete_all"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Alle importierten Quests löschen"
                android:background="@drawable/aero_button"
                android:backgroundTint="#FFEBEE"
                android:textColor="#D32F2F"
                android:layout_marginBottom="30dp" />

            <!-- SEKTION: APP -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APP"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:shadowColor="#1565C0"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="10"
                android:layout_marginBottom="15dp" />

            <TextView
                android:id="@+id/tv_app_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="@drawable/quest_card_bg"
                android:text="Version 1.0.1"
                android:textColor="#0D47A1"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>