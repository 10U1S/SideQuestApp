<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center"
    android:background="#A0000000"> <!-- Dunkler, halbtransparenter Hintergrund -->

    <LinearLayout
        android:id="@+id/polaroid_card_container"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:background="@drawable/polaroid_bg"
        android:orientation="vertical"
        android:elevation="8dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/iv_detail_photo"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tv_detail_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:textColor="#222222"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/permanent_marker" />

        <View
            android:id="@+id/detail_rarity_indicator"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="end"
            android:layout_marginEnd="10dp"
            android:background="@drawable/rarity_circle"
            android:elevation="10dp" />
    </LinearLayout>

</LinearLayout>
