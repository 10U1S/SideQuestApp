<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/soft_background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:title="" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SideQuest"
            android:textSize="44sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:shadowColor="#1565C0"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="20"
            android:layout_marginBottom="50dp" />

        <Button
            android:id="@+id/btn_start_app"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="START"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/aero_button"
            android:backgroundTint="@null"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_open_logbook"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="LOGBUCH"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/aero_button"
            android:backgroundTint="@null" />

    </LinearLayout>
</LinearLayout>